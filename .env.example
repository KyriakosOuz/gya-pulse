# Copy to Vercel project env vars. With these set, providers do REAL OAuth;
# without them, /api/connect runs in demo mode (simulated connect).

# Where the app is hosted (used to build redirect URIs)
OAUTH_REDIRECT_BASE=https://gya-pulse.vercel.app

# HMAC secret for signing the OAuth `state` (CSRF). Use a long random string.
OAUTH_STATE_SECRET=

# Google (one OAuth client for GA4 + Ads + Search Console + Merchant Center)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=   # for Google Ads API data calls (from your MCC)

# Meta (Business app + Facebook Login for Business)
META_APP_ID=
META_APP_SECRET=
META_LOGIN_CONFIG_ID=         # Facebook Login for Business configuration id

# Optional: Vercel KV for durable token storage (else in-memory, dev only)
KV_REST_API_URL=
KV_REST_API_TOKEN=
